# vLLM server configuration (real/GPU mode). Placeholders only — no secrets.
BIG_BRAIN_MODEL=<your-big-instruct-model>
BIG_BRAIN_MAX_LEN=8192
BIG_BRAIN_API_KEY=

SMALL_BRAIN_MODEL=<your-small-instruct-model>
SMALL_BRAIN_MAX_LEN=8192
SMALL_BRAIN_API_KEY=

# Token for gated/private models on the Hugging Face Hub (leave blank for public)
HUGGING_FACE_HUB_TOKEN=

# Where to cache downloaded model weights on the host
HF_CACHE=./hf-cache
