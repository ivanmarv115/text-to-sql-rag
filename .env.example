# Copy to `.env` and adjust. These defaults run the full demo in mock mode.
# Everything here is a non-secret placeholder for a local demo on synthetic data.
# Replace the demo passwords/secret before exposing this anywhere real.

# ---- LLM mode --------------------------------------------------------------
# mock = canned SQL, no model server, no GPU (default). vllm = real models.
LLM_MODE=mock

# ---- App / audit (Chainlit) database --------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=app_demo_pw
CHAINLIT_DB_NAME=chainlit
# Generate a real one with: chainlit create-secret
CHAINLIT_AUTH_SECRET=change-me-run-chainlit-create-secret

# ---- Read-only clinic (target) database -----------------------------------
PG_DBNAME=clinic_demo
PG_USER=llm_readonly
PG_PASSWORD=readonly_demo_pw

# ---- Demo login (auto-created on startup; disable for real deployments) ----
CREATE_DEMO_USER=true
DEMO_USERNAME=demo
DEMO_PASSWORD=demo

# ---- Retrieval -------------------------------------------------------------
# blank = auto: offline embedder in mock mode, bge-m3 in vllm mode
EMBEDDING_PROVIDER=
MAX_CONTEXT_ITEMS=8
MAX_FULL_DDL=6
MAX_SUMMARY_DDL=12
MAX_RESULT_ROWS=1000
MAX_HISTORY_TURNS=10
SEED_ON_STARTUP=true

# ---- vLLM servers (only used when LLM_MODE=vllm) --------------------------
VLLM_BIG_BRAIN_BASE_URL=http://<host>:8000/v1
VLLM_BIG_BRAIN_MODEL=big-instruct-model
VLLM_BIG_BRAIN_API_KEY=
VLLM_BIG_BRAIN_TEMPERATURE=0.1
VLLM_BIG_BRAIN_TOP_P=0.95
VLLM_BIG_BRAIN_TOP_K=64
VLLM_SMALL_BRAIN_BASE_URL=http://<host>:8001/v1
VLLM_SMALL_BRAIN_MODEL=small-instruct-model
VLLM_SMALL_BRAIN_API_KEY=
VLLM_SMALL_BRAIN_TEMPERATURE=1.0
VLLM_SMALL_BRAIN_TOP_P=0.95
VLLM_SMALL_BRAIN_TOP_K=64

# ---- Misc ------------------------------------------------------------------
APP_PORT=8000
DEBUG_CHAT=false
LOG_LEVEL=INFO

# ---- CI/CD (production image push; not needed locally) --------------------
REGISTRY_ORG=your-org
IMAGE_TAG=latest
